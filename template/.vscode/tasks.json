{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "BundleScripts",
			"type": "shell",
			"command": "darklua",
			"args": [
				"process",
				"--config",
				"darklua.json",
				"${input:entryFile}",
				"${input:outputFile}"
			],
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			},
			"problemMatcher": []
		},
		{
			"label": "CopyToClipboard",
			"type": "shell",
			"command": "cat ${input:outputFile} | clip",
			"presentation": {
				"reveal": "silent",
				"panel": "shared"
			},
			"problemMatcher": []
		},
		{
			"label": "BundleScripts&CopyToClipboard",
			"dependsOrder": "sequence",
			"dependsOn": [
				"BundleScripts",
				"CopyToClipboard"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			},
			"problemMatcher": []
		}
	],
	"inputs": [
		{
			"id": "entryFile",
			"type": "promptString",
			"description": "Entrypoint script",
			"default": "init.luau"
		},
		{
			"id": "outputFile",
			"type": "promptString",
			"description": "Output script",
			"default": "CPU0.lua"
		}
	]
}